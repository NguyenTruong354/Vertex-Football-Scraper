# ============================================================
# .env.example — PostgreSQL connection template
# ============================================================
# Copy file này thành .env và điền thông tin kết nối của bạn:
#   cp .env.example .env
#
# .env đã được thêm vào .gitignore → không push credentials lên git


# Aiven PostgreSQL — lấy từ console.aiven.io
# Connection → Service URI

DATABASE_URL=postgres://avnadmin:YOURPASSWORD@pg-xxx.aivencloud.com:PORT/defaultdb?sslmode=require

# Đường dẫn đến file ca.pem đã download
PGSSLROOTCERT=D:\Vertex_Football_Doc\ca.pem

# Discord Webhooks — scheduler_master.py notifications
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL

# Default webhook (fallback if others are not set)
DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# [Optional] Multi-channel routing for better organization:
# Channel for Live Matches & Goals (🟢 ⚽ 🏁)
DISCORD_WEBHOOK_LIVE=
# Channel for Errors & Failures (🔴)
DISCORD_WEBHOOK_ERROR=
# Channel for System Logs & Daily Maintenance (ℹ️ 🔧 ♻️)
DISCORD_WEBHOOK_INFO=