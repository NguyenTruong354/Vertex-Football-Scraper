# ============================================================
# .env.example — PostgreSQL connection template
# ============================================================
# Copy file này thành .env và điền thông tin kết nối của bạn:
#   cp .env.example .env
#
# .env đã được thêm vào .gitignore → không push credentials lên git


# Aiven PostgreSQL — lấy từ console.aiven.io
# Connection → Service URI

DATABASE_URL=postgres://avnadmin:YOURPASSWORD@pg-xxx.aivencloud.com:PORT/defaultdb?sslmode=require

# Đường dẫn đến file ca.pem đã download
PGSSLROOTCERT=D:\Vertex_Football_Doc\ca.pem