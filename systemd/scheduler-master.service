[Unit]
Description=Vertex Football Master Scheduler — All Leagues
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=nguyenhuutruong354
WorkingDirectory=/opt/vertex-football-scraper
ExecStart=/opt/vertex-football-scraper/.venv/bin/python scheduler_master.py
Restart=always
RestartSec=30
Environment=PYTHONUNBUFFERED=1

StandardOutput=journal
StandardError=journal
SyslogIdentifier=scheduler-master

[Install]
WantedBy=multi-user.target
